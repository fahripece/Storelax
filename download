   'fi-threshold','fi-threshold2','fi-notes','fi-cost','fi-sale','fi-owner','fi-po',
   'fi-cpu','fi-ram','fi-storage'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('fi-date').value='';
  document.getElementById('fi-cat').value='';
  document.getElementById('fi-ptype').value='';
  document.getElementById('fi-company').value='';
  document.getElementById('fi-condition').value='New';
  document.getElementById('fi-tax-yes').checked=false;
  document.getElementById('fi-tax-no').checked=false;
  document.getElementById('fi-taxrate').value='8.875';
  document.getElementById('fi-taxrate-row').style.display='none';
  document.getElementById('fi-scan-checkout').value='-1';
  document.getElementById('fi-ebay-status').value='not_listed';
  document.getElementById('fi-ebay-id').value='';
  document.getElementById('fi-ebay-price').value='';
  document.getElementById('fi-ebay-fields').style.display='none';
  document.getElementById('fi-step2').style.display='none';

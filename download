{% extends "base.html" %}
{% block title %}Inventory · Storelax{% endblock %}
{% block content %}
<!-- SCAN BAR -->
<div class="scan-bar" id="scanBar" style="display:none">
  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><path d="M3 5h3M3 9h3M3 19h3M3 15h3M18 5h3M18 9h3M18 15h3M18 19h3M7 3v5M7 16v5M17 3v5M17 16v5M7 8h10v8H7z"/></svg>
  <div class="scan-mode-tabs">
    <button class="smt active" onclick="setScanMode('lookup')">🔍 Look Up</button>
    <button class="smt" onclick="setScanMode('checkout')">📤 Check Out</button>
    <button class="smt" onclick="setScanMode('checkin')">📥 Check In</button>
  </div>
  <input id="scanInput" placeholder="Scan barcode or type serial / model / SKU…" autocomplete="off" onkeydown="if(event.key==='Enter')doScan(this.value)">
  <div id="scanResult" class="scan-result" style="display:none"></div>
  <button class="btn btn-sm" style="background:rgba(255,255,255,0.1);color:#fff;border:1px solid rgba(255,255,255,0.2)" onclick="toggleScan()">✕ Close</button>
</div>
<!-- TOPBAR -->
<div class="topbar">
  <span class="topbar-title">Inventory</span>
  <span class="topbar-sub" id="itemCount"></span>
  <div class="topbar-right">
    <button class="btn btn-secondary btn-sm" onclick="toggleScan()">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5h3M3 9h3M3 19h3M3 15h3M18 5h3M18 9h3M18 15h3M18 19h3M7 3v5M7 16v5M17 3v5M17 16v5M7 8h10v8H7z"/></svg>
      Scanner <small style="opacity:.5;font-size:10px">F2</small>
    </button>
    <div style="position:relative">
      <button class="btn btn-secondary btn-sm" onclick="toggleExportMenu()">↓ Export</button>
      <div id="exportMenu" style="display:none;position:absolute;right:0;top:calc(100% + 4px);background:#fff;border:1px solid #ddd;border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:100;min-width:160px;overflow:hidden">
        <a href="/export/excel" class="export-opt">📊 Excel (.xlsx)</a>
        <a href="/export/csv" class="export-opt">📄 CSV</a>
        {% if session.get('role')=='admin' %}
        <div style="border-top:1px solid #eee"></div>
        <a href="#" class="export-opt" onclick="event.preventDefault();closeExportMenu();openModal('importModal')">📥 Import Excel</a>
        {% endif %}
      </div>
    </div>
    {% if session.get('role')=='admin' %}
    <button class="btn btn-secondary btn-sm" id="massDeleteBtn" style="display:none;color:#b91c1c" onclick="massDelete()">🗑 Delete (<span id="selCount">0</span>)</button>
    <button class="btn btn-secondary btn-sm" id="massPrintBtn" style="display:none" onclick="printSelectedLabels()">🏷 Print Labels (<span id="selCountPrint">0</span>)</button>
    {% endif %}
    <button class="btn btn-secondary btn-sm" onclick="openModal('catModal')">+ Category</button>
    <button class="btn btn-primary btn-sm" onclick="openAddItem()">+ Add Item</button>
  </div>
</div>

<div style="display:flex;flex:1;overflow:hidden">
<div style="flex:1;overflow-y:auto;padding:20px 22px">

{% if alerts %}
<div id="lowStockBanner" style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:12px 16px;margin-bottom:16px;display:flex;align-items:flex-start;gap:10px">
  <span style="font-size:18px;flex-shrink:0">🔴</span>
  <div>
    <div style="font-weight:600;font-size:13px;color:#991b1b;margin-bottom:4px">{{ alerts|length }} item{{ 's' if alerts|length != 1 else '' }} low on stock</div>
    <div style="font-size:12px;color:#b91c1c">
      {% for a in alerts[:6] %}<span style="margin-right:10px">{{ a.name }} — <strong>{{ (a.qty or 0) - (a.qty_out or 0) }} left</strong> (threshold: {{ a.low_stock_threshold }})</span>{% endfor %}
      {% if alerts|length > 6 %}<span>…and {{ alerts|length - 6 }} more</span>{% endif %}
    </div>
  </div>
  <button onclick="document.getElementById('lowStockBanner').style.display='none'" style="margin-left:auto;background:none;border:none;cursor:pointer;color:#b91c1c;font-size:16px">✕</button>
</div>
{% endif %}

<!-- STATS -->
<div class="stats">
  <div class="stat"><div class="stat-l">Total Items</div><div class="stat-v" id="st-total">—</div></div>
  <div class="stat"><div class="stat-l">Checked Out</div><div class="stat-v red" id="st-out">—</div></div>
  <div class="stat"><div class="stat-l">Low Stock</div><div class="stat-v" id="st-low" style="color:#b45309">—</div></div>
  <div class="stat"><div class="stat-l">Stock Value</div><div class="stat-v" id="st-val" style="font-size:18px">—</div></div>
</div>

<!-- FILTERS -->
<div class="flex gap-2" style="margin-bottom:14px;flex-wrap:wrap">
  <div style="position:relative;flex:1;min-width:180px">
    <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);width:14px;height:14px;color:#aaa" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <input id="searchInput" class="input" style="padding-left:30px" placeholder="Search name, serial, owner, manufacturer…" oninput="loadItemsDebounced()">
  </div>
  <select id="catFilter" class="select" style="width:auto;min-width:140px" onchange="loadItems()">
    <option value="">All Categories</option>
    {% for cat in categories %}<option value="{{ cat.id }}">{{ cat.name }}</option>{% endfor %}
  </select>
  <select id="ptypeFilter" class="select" style="width:auto;min-width:130px" onchange="loadItems()">
    <option value="">All Types</option>
    {% for pt in product_types %}<option value="{{ pt.id }}">{{ pt.name }}</option>{% endfor %}
  </select>
  <select id="statusFilter" class="select" style="width:auto;min-width:120px" onchange="loadItems()">
    <option value="">All Status</option>
    <option value="in">Available</option>
    <option value="out">Checked Out</option>
    <option value="low">🔴 Low Stock</option>
  </select>
  <select id="sortFilter" class="select" style="width:auto;min-width:110px" onchange="loadItems()">
    <option value="name">Sort: Name</option>
    <option value="shelf">Sort: Shelf</option>
    <option value="cat">Sort: Category</option>
    <option value="date">Sort: Purchase Date</option>
  </select>
</div>

<!-- TABLE -->
<div class="table-wrap">
  <table>
    <thead><tr>
      {% if session.get('role')=='admin' %}
      <th style="width:36px;padding:10px 8px 10px 14px"><input type="checkbox" id="selectAll" onchange="toggleSelectAll(this.checked)"></th>
      {% endif %}
      <th>Item / Manufacturer</th>
      <th>Category</th>
      <th>Serial / SKU</th>
      <th>Shelf</th>
      <th>Condition</th>
      <th>Status / Qty</th>
      <th>Cost / Sale</th>
      <th></th>
    </tr></thead>
    <tbody id="itemTableBody"><tr class="empty-row"><td colspan="9">Loading…</td></tr></tbody>
  </table>
</div>
</div>

<!-- DETAIL PANEL -->
<div class="detail hidden" id="detailPanel">
  <div class="detail-hdr">
    <div style="display:flex;align-items:flex-start;gap:8px">
      <div style="flex:1"><div class="detail-name" id="dp-name"></div><div class="detail-model" id="dp-model"></div></div>
      <button class="btn btn-sm btn-secondary" style="padding:4px 8px" onclick="closeDetail()">✕</button>
    </div>
    <div style="margin-top:10px" id="dp-status"></div>
  </div>
  <div class="detail-body"><div class="dl" id="dp-fields"></div>
    <!-- Mod history section -->
    <div id="dp-mod-section" style="display:none;margin-top:12px">
      <div class="section-hdr" style="margin-top:0">🔧 Modification History</div>
      <div id="dp-mod-history"></div>
    </div>
    <!-- Child items section -->
    <div id="dp-children-section" style="display:none;margin-top:12px">
      <div class="section-hdr" style="margin-top:0">🔗 Removed Components (Linked Items)</div>
      <div id="dp-children-list"></div>
    </div>
  </div>
  <div class="detail-foot" id="dp-actions"></div>
</div>
</div>

<!-- ══ ADD / EDIT ITEM MODAL ══ -->
<div class="overlay" id="itemModal">
  <div class="modal" style="width:620px;max-height:88vh">
    <div class="modal-header">
      <div>
        <div class="modal-title" id="itemModalTitle">Add Item</div>
        <div id="fi-sku-display" style="display:none;font-size:11px;font-family:monospace;color:#1d4ed8;margin-top:2px"></div>
      </div>
      <button class="modal-close" onclick="closeModal('itemModal')">✕</button>
    </div>
    <div class="modal-body" style="padding:16px 20px">
      <input type="hidden" id="editItemId">

      <!-- ── Step 1: Category (always visible, pick first) ── -->
      <div style="background:#f0f7ff;border:1px solid #bfdbfe;border-radius:8px;padding:12px 14px;margin-bottom:16px">
        <label class="label" style="color:#1e40af;margin-bottom:6px">1. Pick a Category *</label>
        <div style="display:flex;gap:8px;align-items:center">
          <select class="select" id="fi-cat" onchange="onCatChange()" style="flex:1">
            <option value="">— Select a category first —</option>
            {% for cat in categories %}<option value="{{ cat.id }}" data-name="{{ cat.name }}">{{ cat.name }}</option>{% endfor %}
          </select>
          <button class="btn btn-secondary btn-sm" onclick="openModal('catModal')" style="white-space:nowrap">+ New</button>
        </div>
      </div>

      <!-- ── Step 2: Fields (show after category picked) ── -->
      <div id="fi-step2" style="display:none">

        <!-- Identification -->
        <div class="section-hdr" style="margin-top:0">Identification</div>
        <div class="field"><label class="label">Product Name *</label><input class="input" id="fi-name" placeholder="e.g. Dell PowerEdge R740"></div>
        <div class="field-row">
          <div class="field"><label class="label">Manufacturer</label><input class="input" id="fi-manufacturer" placeholder="e.g. Dell, Cisco, HP"></div>
          <div class="field"><label class="label">Model / Part #</label><input class="input mono" id="fi-model" placeholder="e.g. R740-16C"></div>
        </div>
        <div class="field-row">
          <div class="field"><label class="label" id="fi-serial-label">Serial Number</label><input class="input mono" id="fi-serial" placeholder="Scan or type"></div>
          <div class="field">
            <label class="label" id="fi-sku-label">Vendor SKU <span style="font-weight:400;font-size:10px;color:#94a3b8">(leave blank = auto-generate)</span></label>
            <input class="input mono" id="fi-sku" placeholder="Optional — we'll create one if blank">
          </div>
        </div>
        <div class="field-row">
          <div class="field"><label class="label">Product Type</label>
            <select class="select" id="fi-ptype" onchange="onPtypeChange()">
              <option value="">— Select Type —</option>
              {% for pt in product_types %}<option value="{{ pt.id }}" data-sr="{{ pt.serial_required }}" data-skur="{{ pt.sku_required }}" data-qty="{{ pt.qty_tracked }}">{{ pt.name }}</option>{% endfor %}
            </select>
          </div>
          <div class="field"><label class="label">Condition *</label>
            <select class="select" id="fi-condition">
              <option value="New">New</option>
              <option value="Used-VG">Used — Very Good</option>
              <option value="Used-Good">Used — Good</option>
              <option value="Used">Used</option>
              <option value="For Parts">For Parts</option>
            </select>
          </div>
        </div>

        <!-- Category-specific required fields -->
        <div id="fi-cat-fields"></div>

        <!-- Hardware Specs (auto-show for compute categories) -->
        <div id="hw-specs-section" style="display:none">
          <div class="section-hdr">Hardware Specs</div>
          <div class="field-row">
            <div class="field"><label class="label">CPU</label><input class="input" id="fi-cpu" placeholder="e.g. i7-13700K"></div>
            <div class="field"><label class="label">RAM</label><input class="input" id="fi-ram" placeholder="e.g. 32GB DDR5"></div>
          </div>
          <div class="field"><label class="label">Storage</label><input class="input" id="fi-storage" placeholder="e.g. 1TB NVMe SSD"></div>
        </div>

        <!-- Purchase Info -->
        <div class="section-hdr">Purchase Info</div>
        <div class="field-row">
          <div class="field">
            <label class="label">Company <span style="font-weight:400;font-size:10px;color:#94a3b8">(where purchased)</span></label>
            <div style="display:flex;gap:6px">
              <select class="select" id="fi-company" style="flex:1">
                <option value="">— Select company —</option>
                {% for co in companies %}<option value="{{ co.id }}">{{ co.name }}</option>{% endfor %}
              </select>
              <button class="btn btn-secondary btn-sm" onclick="quickAddCompany()" title="Add new company">+</button>
            </div>
          </div>
          <div class="field">
            <label class="label">PO # / Order #</label>
            <input class="input mono" id="fi-po" placeholder="e.g. 114-2938471-0038671">
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label class="label">Purchase Date</label>
            <div style="display:flex;gap:6px">
              <input class="input" id="fi-date" type="date" style="flex:1">
              <button class="btn btn-secondary btn-sm" onclick="document.getElementById('fi-date').value=new Date().toISOString().split('T')[0]" title="Set to today">Today</button>
            </div>
          </div>
          <div class="field"><label class="label">Shelf Location</label><input class="input" id="fi-shelf" placeholder="e.g. A3, Shelf 7"></div>
        </div>
        <div class="field-row">
          <div class="field"><label class="label">Owner / Company</label><input class="input" id="fi-owner" placeholder="e.g. DSS Management Inc"></div>
        </div>

        <!-- Qty (conditional) -->
        <div class="field-row" id="fi-qty-row" style="display:none">
          <div class="field"><label class="label">Quantity</label><input class="input" id="fi-qty" type="number" min="0" placeholder="e.g. 50"></div>
          <div class="field"><label class="label">Low Stock Alert ≤</label><input class="input" id="fi-threshold" type="number" min="0" placeholder="0 = off"></div>
        </div>
        <div class="field" id="fi-threshold-single" style="display:none">
          <label class="label">Low Stock Alert ≤</label>
          <input class="input" id="fi-threshold2" type="number" min="0" placeholder="0 = disabled" style="max-width:160px">
        </div>

        <!-- Cost & Pricing -->
        <div class="section-hdr">Cost &amp; Pricing</div>
        <div class="field-row">
          <div class="field"><label class="label">Cost Price ($)</label><input class="input" id="fi-cost" type="number" step="0.01" min="0" placeholder="0.00" oninput="updateProfitPreview()"></div>
          <div class="field"><label class="label">Sale Price ($)</label><input class="input" id="fi-sale" type="number" step="0.01" min="0" placeholder="0.00" oninput="updateProfitPreview()"></div>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:16px">
          <div id="profit-preview" style="font-size:12px;color:#475569;min-height:18px"></div>
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-size:12px;font-weight:600;color:#475569">Tax Paid:</span>
            <label style="display:flex;align-items:center;gap:5px;cursor:pointer;font-size:13px"><input type="radio" name="fi-tax" id="fi-tax-yes" value="1" onchange="onTaxChange()"> Yes</label>
            <label style="display:flex;align-items:center;gap:5px;cursor:pointer;font-size:13px"><input type="radio" name="fi-tax" id="fi-tax-no" value="0" onchange="onTaxChange()"> No</label>
          </div>
        </div>
        <div class="field" id="fi-taxrate-row" style="display:none">
          <label class="label">Tax Rate (%)</label>
          <input class="input" id="fi-taxrate" type="number" step="0.01" min="0" value="8.875" style="max-width:120px">
        </div>

        <div class="field"><label class="label">Notes</label><textarea class="input" id="fi-notes" style="min-height:56px;resize:vertical"></textarea></div>

        <!-- Advanced -->
        <details style="margin-top:8px">
          <summary style="cursor:pointer;font-size:12px;color:#94a3b8;font-weight:600;letter-spacing:.5px;text-transform:uppercase;padding:6px 0">Advanced Options</summary>
          <div style="margin-top:10px">
            <div class="field">
              <label class="label">Barcode Scan on Checkout</label>
              <select class="select" id="fi-scan-checkout">
                <option value="-1">Inherit from product type</option>
                <option value="0">No — skip scan for this item</option>
                <option value="1">Yes — require scan for this item</option>
              </select>
            </div>
            <div class="field">
              <label class="label">eBay Status</label>
              <select class="select" id="fi-ebay-status" onchange="document.getElementById('fi-ebay-fields').style.display=this.value!=='not_listed'?'':'none'">
                <option value="not_listed">Not Listed</option>
                <option value="listed">Listed on eBay</option>
                <option value="sold">Sold on eBay</option>
              </select>
            </div>
            <div class="field-row" id="fi-ebay-fields" style="display:none">
              <div class="field"><label class="label">eBay Listing ID</label><input class="input" id="fi-ebay-id" placeholder="e.g. 123456789012" style="font-family:monospace"></div>
              <div class="field"><label class="label">Listed Price</label><input class="input" id="fi-ebay-price" type="number" step="0.01" placeholder="0.00"></div>
            </div>
          </div>
        </details>

      </div><!-- end fi-step2 -->
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('itemModal')">Cancel</button>
      <button class="btn btn-danger" id="deleteItemBtn" style="display:none;margin-right:auto" onclick="deleteItem()">🗑 Delete</button>
      <button class="btn btn-primary" id="saveItemBtn" onclick="saveItem()">Save Item</button>
    </div>
  </div>
</div>

<!-- ══ CHECKOUT MODAL ══ -->
<div class="overlay" id="checkoutModal">
  <div class="modal modal-sm">
    <div class="modal-header"><div class="modal-title">Check Out Item</div><button class="modal-close" onclick="closeModal('checkoutModal')">✕</button></div>
    <div class="modal-body">
      <div style="background:#f8f8f7;border-radius:7px;padding:12px;margin-bottom:16px">
        <div style="font-weight:600" id="co-name"></div>
        <div style="font-size:12px;color:#888;font-family:monospace;margin-top:2px" id="co-serial"></div>
      </div>
      <!-- Scan requirement banner — shown only when needed -->
      <div id="co-scan-required" style="display:none;background:#fef3c7;border:1px solid #fcd34d;border-radius:7px;padding:10px 12px;margin-bottom:14px">
        <div style="font-size:12px;font-weight:600;color:#92400e;margin-bottom:6px">⚠️ Scan Required — scan the item barcode before checkout</div>
        <div style="display:flex;gap:6px">
          <input class="input" id="co-scan-input" placeholder="Scan or type serial / SKU…" style="font-family:monospace;font-size:13px" autocomplete="off">
          <button class="btn btn-secondary btn-sm" onclick="verifyScanCheckout()">Verify</button>
        </div>
        <div id="co-scan-status" style="font-size:12px;margin-top:6px;display:none"></div>
      </div>
      <div class="field"><label class="label">Tech Name / Initials *</label><input class="input" id="co-who" placeholder="e.g. Danny W"></div>
      <div class="field"><label class="label">Job Reference / Customer</label><input class="input" id="co-jobref" placeholder="e.g. Acme Corp install"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('checkoutModal')">Cancel</button>
      <button class="btn btn-danger" id="coBtn" onclick="confirmCheckout()">📤 Check Out</button>
    </div>
  </div>
</div>

<!-- ══ MODIFY ITEM MODAL ══ -->
<div class="overlay" id="modifyModal">
  <div class="modal">
    <div class="modal-header"><div class="modal-title">🔧 Modify Item Component</div><button class="modal-close" onclick="closeModal('modifyModal')">✕</button></div>
    <div class="modal-body">
      <div style="background:#f8f8f7;border-radius:7px;padding:12px;margin-bottom:16px">
        <div style="font-weight:600;font-size:13px" id="mod-item-name">—</div>
        <div style="font-size:11.5px;color:#888;margin-top:4px" id="mod-item-specs">—</div>
      </div>
      <div class="field-row">
        <div class="field">
          <label class="label">Field Being Changed *</label>
          <select class="select" id="mod-field" onchange="modFieldChanged()">
            <option value="ram">RAM</option>
            <option value="cpu">CPU</option>
            <option value="storage">Storage</option>
            <option value="condition">Condition</option>
            <option value="notes">Notes</option>
            <option value="cost_price">Cost Price</option>
            <option value="sale_price">Sale Price</option>
          </select>
        </div>
        <div class="field">
          <label class="label">Old Value</label>
          <input class="input" id="mod-old" placeholder="Previous value" readonly style="background:#f5f5f3;color:#888">
        </div>
      </div>
      <div class="field">
        <label class="label">New Value *</label>
        <input class="input" id="mod-new" placeholder="Updated value (e.g. 16GB DDR4)">
      </div>
      <div class="field">
        <label class="label">Modification Notes</label>
        <textarea class="input" id="mod-notes" rows="2" placeholder="e.g. Removed one 8GB stick for repair order #441"></textarea>
      </div>
      <!-- Spawn child item -->
      <div style="border:1px solid #e5e3de;border-radius:8px;padding:14px;margin-top:6px">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
          <input type="checkbox" id="mod-spawn-cb" onchange="toggleSpawnForm()" style="width:15px;height:15px;cursor:pointer">
          <label for="mod-spawn-cb" style="font-size:13px;font-weight:600;cursor:pointer">Create inventory item for removed component</label>
        </div>
        <div id="mod-spawn-form" style="display:none">
          <div class="field">
            <label class="label">Component Item Name *</label>
            <input class="input" id="spawn-name" placeholder="e.g. 8GB DDR4 SO-DIMM (Samsung)">
          </div>
          <div class="field-row">
            <div class="field">
              <label class="label">Condition</label>
              <select class="select" id="spawn-cond">
                <option value="Used">Used</option><option value="Refurbished">Refurbished</option><option value="New">New</option>
              </select>
            </div>
            <div class="field">
              <label class="label">Cost / Value</label>
              <input class="input" id="spawn-cost" placeholder="0.00" type="number" step="0.01">
            </div>
          </div>
          <div class="field">
            <label class="label">Shelf Location</label>
            <input class="input" id="spawn-shelf" placeholder="e.g. PARTS-BIN-A">
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('modifyModal')">Cancel</button>
      <button class="btn btn-primary" id="modBtn" onclick="confirmModify()">Save Modification</button>
    </div>
  </div>
</div>

<!-- ══ EBAY MODAL ══ -->
<div class="overlay" id="ebayModal">
  <div class="modal modal-sm">

function onRowCheck(cb){const id=parseInt(cb.dataset.id);if(cb.checked)selectedIds.add(id);else selectedIds.delete(id);updateSelectionUI();}
function toggleSelectAll(checked){allItems.forEach(i=>{if(checked)selectedIds.add(i.id);else selectedIds.delete(i.id);});updateSelectionUI();document.querySelectorAll('.row-cb').forEach(cb=>{cb.checked=selectedIds.has(parseInt(cb.dataset.id));});}
function updateSelectionUI(){
  const n=selectedIds.size;
  const btn=document.getElementById('massDeleteBtn');
  const pBtn=document.getElementById('massPrintBtn');
  if(btn){btn.style.display=n>0?'':'none';document.getElementById('selCount').textContent=n;}
  if(pBtn){pBtn.style.display=n>0?'':'none';document.getElementById('selCountPrint').textContent=n;}
}
async function massDelete(){
  const n=selectedIds.size; if(!n)return;
  if(!confirm(`Delete ${n} selected item${n===1?'':'s'}? This cannot be undone.`))return;
  const res=await api('/api/item/delete',{ids:[...selectedIds]});
  if(res.ok){toast(`Deleted ${res.deleted} item${res.deleted===1?'':'s'}`,'warn');selectedIds.clear();updateSelectionUI();closeDetail();loadItems();}
  else toast(res.msg||'Error','err');
}

// ── Product type field logic ──
// ── Category profile field definitions ──────────────────────────────────────
// ── Dynamic category fields (defined in Admin → Category Field Profiles) ──────
// CATEGORY_FIELDS injected from server: {cat_id: [{field_label,field_key,field_type,placeholder,required}]}
function onCatChange(){
  const sel=document.getElementById('fi-cat');
  const catId=sel.value;
  if(!catId){document.getElementById('fi-step2').style.display='none';return;}
  document.getElementById('fi-step2').style.display='';
  renderCatFields(catId,sel.options[sel.selectedIndex]?.text||'');
  checkHwSpecs();
}
function renderCatFields(catId,catName){
  const container=document.getElementById('fi-cat-fields');
  const fields=(CATEGORY_FIELDS[String(catId)])||[];
  if(!fields.length){container.innerHTML='';return;}
  const pairs=[],singles=[];
  fields.forEach(f=>{
    const eid='fi-dyn-'+f.field_key;
    const reqMark=f.required?'<span style="color:#b91c1c"> *</span>':'';
    if(f.field_type==='checkbox'){
      singles.push('<div class="field" style="margin-bottom:10px"><label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:13px"><input type="checkbox" id="'+eid+'" style="width:15px;height:15px"> '+f.field_label+'</label></div>');
    } else {
      const typeAttr=f.field_type==='number'?' type="number"':'';
      pairs.push('<div class="field"><label class="label">'+f.field_label+reqMark+'</label><input class="input" id="'+eid+'"'+typeAttr+' placeholder="'+(f.placeholder||'')+'"></div>');
    }
  });
  let html='<div class="section-hdr">'+catName+' Fields</div>';
  for(let i=0;i<pairs.length;i+=2){
    html+=pairs[i+1]?'<div class="field-row">'+pairs[i]+pairs[i+1]+'</div>':pairs[i];
  }
  singles.forEach(s=>html+=s);
  container.innerHTML=html;
}
function onPtypeChange(){
  const sel=document.getElementById('fi-ptype');
  const opt=sel.selectedIndex>=0?sel.options[sel.selectedIndex]:null;
  const sr=parseInt(opt?.dataset.sr||0),skur=parseInt(opt?.dataset.skur||0),qtyT=parseInt(opt?.dataset.qty||0);
  document.getElementById('fi-serial-label').innerHTML='Serial Number'+(sr===1?' <span style="color:#b91c1c">*</span>':' <span style="color:#94a3b8;font-size:10px">(optional)</span>');
  document.getElementById('fi-sku-label').innerHTML='Vendor SKU'+(skur===1?' <span style="color:#b91c1c">*</span>':' <span style="font-weight:400;font-size:10px;color:#94a3b8">(leave blank = auto-generate)</span>');
  document.getElementById('fi-qty-row').style.display=qtyT?'grid':'none';
  checkHwSpecs();
}
function checkHwSpecs(){
  const catSel=document.getElementById('fi-cat');
  const ptSel=document.getElementById('fi-ptype');
  const catName=(catSel.options[catSel.selectedIndex]?.text||'').toLowerCase();
  const ptName=(ptSel.options[ptSel.selectedIndex]?.text||'').toLowerCase();
  const combined=catName+' '+ptName;
  const show=HW_CATS.some(k=>combined.includes(k));
  document.getElementById('hw-specs-section').style.display=show?'':'none';
}
function onTaxChange(){
  const yes=document.getElementById('fi-tax-yes').checked;
  document.getElementById('fi-taxrate-row').style.display=yes?'block':'none';
}
function updateProfitPreview(){
  const cost=parseFloat(document.getElementById('fi-cost').value)||0;
  const sale=parseFloat(document.getElementById('fi-sale').value)||0;
  const el=document.getElementById('profit-preview');
  if(cost>0&&sale>0){const p=sale-cost;const pct=((p/cost)*100).toFixed(1);el.innerHTML=p>=0?'<span style="color:#15803d">Profit: $'+p.toFixed(2)+' (+'+pct+'%)</span>':'<span style="color:#b91c1c">Loss: $'+Math.abs(p).toFixed(2)+' ('+pct+'%)</span>';}
  else el.innerHTML='';
}
async function quickAddCompany(){
  const name=prompt('New company name:');
  if(!name?.trim())return;
  const res=await api('/api/company/add',{name:name.trim()});
  if(res.ok){
    const sel=document.getElementById('fi-company');
    const opt=document.createElement('option');
    opt.value=res.id;opt.textContent=res.name;sel.appendChild(opt);sel.value=res.id;
    toast('Company added','ok');
  } else toast(res.msg||'Error','err');
}

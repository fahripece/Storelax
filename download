function openAddItem(){
  _clearItemForm();
  document.getElementById('editItemId').value='';
  document.getElementById('itemModalTitle').textContent='Add Item';
  document.getElementById('deleteItemBtn').style.display='none';
  openModal('itemModal');
}
function editItem(item){
  if(!item)return;
  _clearItemForm();
  document.getElementById('editItemId').value=item.id;
  document.getElementById('itemModalTitle').textContent='Edit Item';
  if(item.internal_sku){const d=document.getElementById('fi-sku-display');d.textContent='Auto SKU: '+item.internal_sku;d.style.display='';}
  document.getElementById('fi-cat').value=item.category_id||'';
  onCatChange();
  setTimeout(()=>{
    document.getElementById('fi-name').value=item.name||'';
    document.getElementById('fi-manufacturer').value=item.manufacturer||'';
    document.getElementById('fi-model').value=item.model||'';
    document.getElementById('fi-serial').value=item.serial||'';
    document.getElementById('fi-sku').value=item.sku||'';
    document.getElementById('fi-shelf').value=item.shelf||'';
    document.getElementById('fi-qty').value=item.qty!=null?item.qty:'';
    document.getElementById('fi-threshold').value=item.low_stock_threshold||'';
    document.getElementById('fi-threshold2').value=item.low_stock_threshold||'';
    document.getElementById('fi-notes').value=item.notes||'';
    document.getElementById('fi-ptype').value=item.product_type_id||'';
    document.getElementById('fi-condition').value=item.condition||'New';
    document.getElementById('fi-owner').value=item.owner_company||'';
    document.getElementById('fi-date').value=item.purchase_date||'';
    document.getElementById('fi-cost').value=item.cost_price!=null?item.cost_price:'';
    document.getElementById('fi-sale').value=item.sale_price!=null?item.sale_price:'';
    document.getElementById('fi-cpu').value=item.cpu||'';
    document.getElementById('fi-ram').value=item.ram||'';
    document.getElementById('fi-storage').value=item.storage||'';
    document.getElementById('fi-po').value=item.po_number||'';
    if(item.company_id)document.getElementById('fi-company').value=item.company_id;
    if(item.tax_paid===1){document.getElementById('fi-tax-yes').checked=true;document.getElementById('fi-taxrate-row').style.display='block';}
    else if(item.tax_paid===0){document.getElementById('fi-tax-no').checked=true;document.getElementById('fi-taxrate-row').style.display='none';}
    document.getElementById('fi-taxrate').value=item.tax_rate||'8.875';
    document.getElementById('fi-scan-checkout').value=item.require_scan_checkout!=null?item.require_scan_checkout:'-1';
    const es=item.ebay_status||'not_listed';
    document.getElementById('fi-ebay-status').value=es;
    document.getElementById('fi-ebay-id').value=item.ebay_listing_id||'';
    document.getElementById('fi-ebay-price').value=item.ebay_listed_price||'';
    document.getElementById('fi-ebay-fields').style.display=es!=='not_listed'?'':'none';
    // Populate dynamic category fields from extra_fields JSON
    const extraFields=JSON.parse(item.extra_fields||'{}');
    const catFields=(CATEGORY_FIELDS[String(item.category_id)])||[];
    catFields.forEach(f=>{
      const el=document.getElementById('fi-dyn-'+f.field_key);if(!el)return;
      if(el.type==='checkbox')el.checked=!!(extraFields[f.field_key]);
      else el.value=extraFields[f.field_key]||'';
    });
    updateProfitPreview();onPtypeChange();checkHwSpecs();
  },50);
  document.getElementById('deleteItemBtn').style.display='';
  openModal('itemModal');
}
async function saveItem(){
  if(!document.getElementById('fi-cat').value){toast('Please select a category first','warn');document.getElementById('fi-cat').focus();return;}
  const name=document.getElementById('fi-name').value.trim();
  if(!name){toast('Product name is required','warn');document.getElementById('fi-name').focus();return;}
  const taxYes=document.getElementById('fi-tax-yes').checked;
  const taxNo=document.getElementById('fi-tax-no').checked;
  if(!taxYes&&!taxNo){toast('Please select Yes or No for Tax Paid','warn');return;}
  const ptOpt=document.getElementById('fi-ptype').options[document.getElementById('fi-ptype').selectedIndex];
  if(parseInt(ptOpt?.dataset.sr||0)===1&&!document.getElementById('fi-serial').value.trim()){toast('Serial number required for this product type','warn');return;}
  if(parseInt(ptOpt?.dataset.skur||0)===1&&!document.getElementById('fi-sku').value.trim()){toast('SKU required for this product type','warn');return;}
  const catId=document.getElementById('fi-cat').value;
  const catName=document.getElementById('fi-cat').options[document.getElementById('fi-cat').selectedIndex]?.text||'';
  // Validate required dynamic category fields
  const catFieldDefs=(CATEGORY_FIELDS[String(catId)])||[];
  for(const f of catFieldDefs){
    if(f.required&&f.field_type!=='checkbox'){
      const el=document.getElementById('fi-dyn-'+f.field_key);
      if(el&&!el.value.trim()){toast(f.field_label+' is required for '+catName,'warn');el.focus();return;}
    }
  }
  const qtyT=parseInt(ptOpt?.dataset.qty||0);
  const threshold=qtyT?(parseInt(document.getElementById('fi-threshold').value)||0):(parseInt(document.getElementById('fi-threshold2').value)||0);
  // Collect dynamic category field values into extra_fields object
  const extra_fields={};
  catFieldDefs.forEach(f=>{
    const el=document.getElementById('fi-dyn-'+f.field_key);if(!el)return;
    extra_fields[f.field_key]=el.type==='checkbox'?el.checked?1:0:el.value.trim()||null;
  });
  pendingSaveData={
    name,
    manufacturer:document.getElementById('fi-manufacturer').value.trim(),
    model:document.getElementById('fi-model').value.trim(),
    serial:document.getElementById('fi-serial').value.trim(),
    sku:document.getElementById('fi-sku').value.trim(),
    category_id:parseInt(document.getElementById('fi-cat').value)||null,
    product_type_id:parseInt(document.getElementById('fi-ptype').value)||null,
    condition:document.getElementById('fi-condition').value,
    owner_company:document.getElementById('fi-owner').value.trim(),
    purchase_date:document.getElementById('fi-date').value,
    shelf:document.getElementById('fi-shelf').value.trim(),
    qty:document.getElementById('fi-qty').value!==''?parseInt(document.getElementById('fi-qty').value):null,
    low_stock_threshold:threshold,
    notes:document.getElementById('fi-notes').value.trim(),
    cpu:document.getElementById('fi-cpu').value.trim(),
    ram:document.getElementById('fi-ram').value.trim(),
    storage:document.getElementById('fi-storage').value.trim(),
    cost_price:document.getElementById('fi-cost').value||null,
    sale_price:document.getElementById('fi-sale').value||null,
    tax_paid:taxYes?1:0,
    tax_rate:parseFloat(document.getElementById('fi-taxrate').value)||8.875,
    require_scan_checkout:parseInt(document.getElementById('fi-scan-checkout').value),
    ebay_status:document.getElementById('fi-ebay-status').value,
    ebay_listing_id:document.getElementById('fi-ebay-id').value.trim()||null,
    ebay_listed_price:document.getElementById('fi-ebay-price').value||null,
    company_id:document.getElementById('fi-company').value||null,
    po_number:document.getElementById('fi-po').value.trim()||null,
    extra_fields,
  };
  const id=document.getElementById('editItemId').value;
  if(id)pendingSaveData.id=parseInt(id);
  const owner=pendingSaveData.owner_company;
  if(owner){
    document.getElementById('ownerConfirmMsg').innerHTML='<strong>CONFIRMATION:</strong> Please verify this item belongs to <strong>"'+owner+'"</strong>.<br><br>If incorrect, click Cancel and contact the System Administrator.';
    closeModal('itemModal');openModal('ownerModal');
  } else {
    await confirmedSaveItem();
  }
}

async function confirmedSaveItem(){
  closeModal('ownerModal');
  if(!pendingSaveData)return;
  const d=pendingSaveData; pendingSaveData=null;
  const res=await api(d.id?'/api/item/edit':'/api/item/add',d);
  if(res.ok){toast(d.id?'Item updated ✓':'Item added ✓','ok');closeModal('itemModal');loadItems();}
  else toast(res.msg||'Error','err');
}
async function deleteItem(){
  const id=document.getElementById('editItemId').value;
  if(!id||!confirm('Delete this item?'))return;
  const res=await api('/api/item/delete',{id:parseInt(id)});
  if(res.ok){toast('Deleted','warn');closeModal('itemModal');closeDetail();loadItems();}
  else toast(res.msg||'Error','err');
}

async function doCheckin(id){
  const item=allItems.find(i=>i.id===id);
  if(!item||!confirm(`Check in "${item.name}"?`))return;
  const res=await api('/api/checkin',{id});
  if(res.ok){toast('Checked in ✓','ok');await loadItems();}
  else toast(res.msg||'Error','err');
}
function openQtyAdjust(id){
  const item=allItems.find(i=>i.id===id);if(!item)return;
  pendingQtyId=id;
  document.getElementById('qty-name').textContent=item.name;
  document.getElementById('qty-avail').textContent=item.available||0;
  document.getElementById('qty-total').textContent=item.qty;
  document.getElementById('qty-amount').value='';document.getElementById('qty-note').value='';
  setQtyAction('add');openModal('qtyModal');
}
function setQtyAction(action){
  qtyAction=action;
  const labels={add:'Amount to Add',remove:'Amount to Use / Remove',set:'Set New Total Quantity'};
  document.getElementById('qty-action-label').textContent=labels[action];
  ['add','remove','set'].forEach(a=>{document.getElementById(`qa-${a}-btn`).className='btn '+(a===action?'btn-primary':'btn-secondary')+' flex-1';document.getElementById(`qa-${a}-btn`).style.justifyContent='center';});
}
async function confirmQtyAdjust(){
  const amount=parseInt(document.getElementById('qty-amount').value);
  if(!amount||amount<0){toast('Enter a valid amount','warn');return}
  const res=await api('/api/qty_adjust',{id:pendingQtyId,action:qtyAction,amount,note:document.getElementById('qty-note').value.trim()});
  if(res.ok){toast('Quantity updated ✓','ok');closeModal('qtyModal');await loadItems();const u=allItems.find(i=>i.id===pendingQtyId);if(u)showDetail(u);}
  else toast(res.msg||'Error','err');
}
async function saveCategory(){
  const name=document.getElementById('cat-name').value.trim();
  if(!name){toast('Name required','warn');return}
  const res=await api('/api/category/add',{name,color:document.getElementById('cat-color').value});
  if(res.ok){toast('Category added ✓','ok');closeModal('catModal');location.reload();}
  else toast(res.msg||'Error','err');
}
async function confirmImport(){
  const file=document.getElementById('importFile').files[0];
  if(!file){toast('Select a file first','warn');return}
  const fd=new FormData();fd.append('file',file);
  const res=await fetch('/import/excel',{method:'POST',body:fd}).then(r=>r.json());
  const el=document.getElementById('importResult');el.style.display='';
  if(res.ok){el.style.cssText='background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;padding:10px;border-radius:7px;margin-top:8px';el.textContent=`✓ Imported ${res.added} items${res.skipped?' ('+res.skipped+' skipped)':''}`;if(res.added>0)setTimeout(()=>{closeModal('importModal');loadItems();},1500);}
  else{el.style.cssText='background:#fef2f2;border:1px solid #fecaca;color:#b91c1c;padding:10px;border-radius:7px;margin-top:8px';el.textContent='Error: '+(res.msg||'Unknown error');}
}
function toggleScan(){scanOpen=!scanOpen;document.getElementById('scanBar').style.display=scanOpen?'flex':'none';if(scanOpen)setTimeout(()=>document.getElementById('scanInput').focus(),50);}
function setScanMode(mode){scanMode=mode;document.querySelectorAll('.smt').forEach((el,i)=>el.classList.toggle('active',['lookup','checkout','checkin'][i]===mode));document.getElementById('scanInput').focus();}
async function doScan(code){
  code=(code||'').trim();document.getElementById('scanInput').value='';if(!code)return;
  const data=await fetch('/api/scan?code='+encodeURIComponent(code)).then(r=>r.json());
  const resEl=document.getElementById('scanResult');resEl.style.display='';
  if(!data.found){resEl.className='scan-result err';resEl.textContent=`Not found: ${code}`;return}
  const item=data.item;
  if(scanMode==='lookup'){resEl.className='scan-result found';resEl.textContent=`✓ ${item.name} — Shelf ${item.shelf}`;await loadItems();showDetail(allItems.find(i=>i.id===item.id));}
  else if(scanMode==='checkout'){if(item.checked_out){resEl.className='scan-result warn';resEl.textContent=`Already out: ${item.name}`}else{openCheckout(item.id);resEl.className='scan-result found';resEl.textContent=`Ready: ${item.name}`}}
  else if(scanMode==='checkin'){if(!item.checked_out){resEl.className='scan-result warn';resEl.textContent=`Already in: ${item.name}`}else{const res=await api('/api/checkin',{id:item.id});if(res.ok){resEl.className='scan-result found';resEl.textContent=`✓ Checked in: ${item.name}`;loadItems();}}}
  setTimeout(()=>{resEl.style.display='none'},4000);
}
function toggleExportMenu(){const m=document.getElementById('exportMenu');m.style.display=m.style.display==='none'?'block':'none';}
function closeExportMenu(){document.getElementById('exportMenu').style.display='none';}
document.addEventListener('click',e=>{if(!e.target.closest('.topbar-right'))closeExportMenu();});
function openModal(id){document.getElementById(id).classList.add('open')}
function closeModal(id){document.getElementById(id).classList.remove('open')}
// Modals only close via the ✕ button — backdrop clicks do nothing
document.addEventListener('keydown',e=>{
  if(e.key==='F2'){toggleScan();e.preventDefault()}
  if(e.key==='Escape'){if(scanOpen)toggleScan();closeDetail();}
  if(e.key==='/'&&!['INPUT','TEXTAREA','SELECT'].includes(document.activeElement.tagName)){document.getElementById('searchInput').focus();e.preventDefault();}
});
function setSort(s){document.getElementById('sortFilter').value=s;loadItems();}

// ── Scan-required checkout ────────────────────────────────────────────────────
let _scanVerified = false;
function openCheckout(id){
  const item=allItems.find(i=>i.id===id);if(!item)return;
  pendingCheckoutId=id; _scanVerified=false;
  document.getElementById('co-name').textContent=item.name;
  document.getElementById('co-serial').textContent=item.serial||item.model||item.sku||'';
  document.getElementById('co-who').value='';document.getElementById('co-jobref').value='';
  // Check if scan is required (item override or product type default)
  const itemReq=item.require_scan_checkout;
  const pt=ptypes.find(p=>p.id===item.product_type_id);
  const ptReq=pt?pt.require_scan_checkout:0;
  const scanReq=(itemReq!=null&&itemReq!==-1)?itemReq:ptReq;
  const scanDiv=document.getElementById('co-scan-required');
  const scanStatus=document.getElementById('co-scan-status');
  if(scanReq){
    scanDiv.style.display='';
    document.getElementById('co-scan-input').value='';
    scanStatus.style.display='none';
    document.getElementById('coBtn').disabled=true;
  } else {
    scanDiv.style.display='none';
    document.getElementById('coBtn').disabled=false;
  }
  openModal('checkoutModal');
  setTimeout(()=>scanReq?document.getElementById('co-scan-input').focus():document.getElementById('co-who').focus(),100);
}
function verifyScanCheckout(){
  const code=document.getElementById('co-scan-input').value.trim();
  const item=allItems.find(i=>i.id===pendingCheckoutId);
  const statusEl=document.getElementById('co-scan-status');
  statusEl.style.display='';
  if(!code){statusEl.style.color='#b91c1c';statusEl.textContent='⚠ Please scan or enter a code';return;}
  const valid=[item.serial,item.sku,item.model].filter(Boolean);
  if(valid.length===0||valid.includes(code)){
    _scanVerified=true;
    statusEl.style.color='#15803d';statusEl.textContent='✓ Verified — '+code;
    document.getElementById('coBtn').disabled=false;
    document.getElementById('co-who').focus();
  } else {
    _scanVerified=false;
    statusEl.style.color='#b91c1c';statusEl.textContent='✕ No match. Expected: '+valid.join(' / ');
    document.getElementById('coBtn').disabled=true;
  }
}
document.getElementById('co-scan-input')?.addEventListener('keydown',e=>{if(e.key==='Enter')verifyScanCheckout();});

async function confirmCheckout(){
  const who=document.getElementById('co-who').value.trim();
  if(!who){toast('Please enter tech name/initials','warn');return;}
  const btn=document.getElementById('coBtn');btn.disabled=true;btn.textContent='Checking out…';
  const scannedCode=document.getElementById('co-scan-input')?.value.trim()||'';
  const res=await api('/api/checkout',{id:pendingCheckoutId,who,job_ref:document.getElementById('co-jobref').value.trim(),scanned_code:scannedCode});
  btn.disabled=false;btn.innerHTML='📤 Check Out';
  if(res.ok){toast('Checked out ✓','ok');closeModal('checkoutModal');await loadItems();const u=allItems.find(i=>i.id===pendingCheckoutId);if(u)showDetail(u);}
  else if(res.msg==='scan_required'){toast('Scan required — please verify the barcode first','warn');}
  else if(res.msg==='scan_mismatch'){toast(res.detail||'Scan mismatch','err');}
  else toast(res.msg||'Error','err');
}

// ── Modify Item ───────────────────────────────────────────────────────────────
let pendingModifyId=null;
function openModify(id){
  const item=allItems.find(i=>i.id===id);if(!item)return;
  pendingModifyId=id;
  document.getElementById('mod-item-name').textContent=item.name;
  const specs=[item.cpu&&('CPU: '+item.cpu),item.ram&&('RAM: '+item.ram),item.storage&&('Storage: '+item.storage)].filter(Boolean).join(' | ');
  document.getElementById('mod-item-specs').textContent=specs||'No hardware specs recorded';
  document.getElementById('mod-spawn-cb').checked=false;
  document.getElementById('mod-spawn-form').style.display='none';
  document.getElementById('mod-notes').value='';document.getElementById('mod-new').value='';
  document.getElementById('spawn-name').value='';document.getElementById('spawn-cost').value='';
  document.getElementById('spawn-shelf').value=item.shelf||'';
  modFieldChanged();
  openModal('modifyModal');
}
function modFieldChanged(){
  const field=document.getElementById('mod-field').value;
  const item=allItems.find(i=>i.id===pendingModifyId);
  if(!item)return;
  const val={ram:item.ram,cpu:item.cpu,storage:item.storage,condition:item.condition,notes:item.notes,cost_price:item.cost_price!=null?item.cost_price.toFixed(2):'',sale_price:item.sale_price!=null?item.sale_price.toFixed(2):''}[field]||'';
  document.getElementById('mod-old').value=val;
  document.getElementById('mod-new').value='';
  // Auto-suggest spawn name for hardware fields
  if(['ram','cpu','storage'].includes(field)&&val){
    document.getElementById('spawn-name').value=val+' (removed from '+item.name+')';
  }
}
function toggleSpawnForm(){
  document.getElementById('mod-spawn-form').style.display=document.getElementById('mod-spawn-cb').checked?'':'none';
}
async function confirmModify(){
  const field=document.getElementById('mod-field').value;
  const newVal=document.getElementById('mod-new').value.trim();
  if(!newVal){toast('New value required','warn');return;}
  const btn=document.getElementById('modBtn');btn.disabled=true;btn.textContent='Saving…';
  const spawnCb=document.getElementById('mod-spawn-cb').checked;
  const payload={
    item_id:pendingModifyId,
    field_changed:field,
    old_value:document.getElementById('mod-old').value,
    new_value:newVal,
    notes:document.getElementById('mod-notes').value.trim(),
  };
  if(spawnCb&&document.getElementById('spawn-name').value.trim()){
    payload.spawn_item={
      name:document.getElementById('spawn-name').value.trim(),
      condition:document.getElementById('spawn-cond').value,
      cost_price:document.getElementById('spawn-cost').value||null,
      shelf:document.getElementById('spawn-shelf').value.trim()||null,
    };
  }
  const res=await api('/api/item/modify',payload);
  btn.disabled=false;btn.textContent='Save Modification';
  if(res.ok){
    toast('Modification saved'+(res.spawned_id?` — new item #${res.spawned_id} created`:''),'ok');
    closeModal('modifyModal');
    await loadItems();
    const u=allItems.find(i=>i.id===pendingModifyId);if(u)showDetail(u);
  } else toast(res.msg||'Error','err');
}

// ── Mod history + children in detail panel ────────────────────────────────────
async function loadModHistory(itemId){
  const sec=document.getElementById('dp-mod-section');
  const hist=document.getElementById('dp-mod-history');
  try{
    const mods=await fetch('/api/item/modifications?item_id='+itemId).then(r=>r.json());
    if(mods.length===0){sec.style.display='none';return;}
    sec.style.display='';
    hist.innerHTML=mods.map(m=>`
      <div class="mod-hist-row">
        <div style="flex:1">
          <div style="font-weight:600;font-size:12.5px">${m.field_changed}: <span style="color:#b91c1c;text-decoration:line-through">${m.old_value||'—'}</span> → <span style="color:#15803d">${m.new_value||'—'}</span></div>
          ${m.notes?`<div style="font-size:11.5px;color:#888;margin-top:2px">${m.notes}</div>`:''}
          ${m.spawned_name?`<div style="margin-top:4px"><span class="lineage-link" onclick="jumpToItem(${m.spawned_item_id})">🔗 Spawned: ${m.spawned_name}</span></div>`:''}
        </div>
        <div style="font-size:11px;color:#aaa;text-align:right;flex-shrink:0">${m.ts.substring(0,10)}<br>${m.modified_by}</div>
      </div>
    `).join('');
  }catch(e){sec.style.display='none';}
}
async function loadChildItems(itemId){
  const sec=document.getElementById('dp-children-section');
  const list=document.getElementById('dp-children-list');
  try{
    const res=await fetch('/api/item/lineage?item_id='+itemId).then(r=>r.json());
    if(!res.ok||res.children.length===0){sec.style.display='none';return;}
    sec.style.display='';
    list.innerHTML=res.children.map(c=>`
      <div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid #f0efec">
        <span style="color:#1d4ed8;font-size:13px">↳</span>
        <span class="lineage-link" onclick="jumpToItem(${c.id})" style="flex:1">${c.name} — ${c.condition||''}${c.shelf?' · '+c.shelf:''}</span>
      </div>
    `).join('');
  }catch(e){sec.style.display='none';}
}
async function jumpToItem(id){
  await loadItems();
  const item=allItems.find(i=>i.id===id);
  if(item){showDetail(item);toast('Jumped to: '+item.name,'ok');}
  else toast('Item not found (may be inactive)','warn');
}

// ── eBay ──────────────────────────────────────────────────────────────────────
let pendingEbayId=null, currentEbayStatus='not_listed';
function openEbay(id){
  const item=allItems.find(i=>i.id===id);if(!item)return;
  pendingEbayId=id;
  document.getElementById('eb-item-name').textContent=item.name;
  currentEbayStatus=item.ebay_status||'not_listed';
  document.querySelectorAll('.ebay-status-btn').forEach(b=>{
    b.classList.toggle('active',b.dataset.status===currentEbayStatus);
  });
  document.getElementById('eb-listing-id').value=item.ebay_listing_id||'';
  document.getElementById('eb-price').value=item.ebay_listed_price||'';
  document.getElementById('eb-date').value=item.ebay_listed_date||'';
  openModal('ebayModal');
}
function setEbayStatus(status,el){
  currentEbayStatus=status;
  document.querySelectorAll('.ebay-status-btn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  const showFields=status!=='not_listed';
  document.getElementById('eb-id-field').style.opacity=showFields?'1':'0.4';
  document.getElementById('eb-price-fields').style.opacity=showFields?'1':'0.4';
}
async function confirmEbay(){
  const btn=document.getElementById('ebayBtn');btn.disabled=true;btn.textContent='Saving…';
  const res=await api('/api/item/ebay',{
    item_id:pendingEbayId,
    ebay_status:currentEbayStatus,
    ebay_listing_id:document.getElementById('eb-listing-id').value.trim(),
    ebay_listed_price:document.getElementById('eb-price').value||null,
    ebay_listed_date:document.getElementById('eb-date').value||null,
  });
  btn.disabled=false;btn.textContent='Save eBay Status';
  if(res.ok){
    toast('eBay status updated ✓','ok');closeModal('ebayModal');
    await loadItems();const u=allItems.find(i=>i.id===pendingEbayId);if(u)showDetail(u);
  } else toast(res.msg||'Error','err');
}

loadItems();
</script>

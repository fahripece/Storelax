<style>
.section-hdr{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:#64748b;padding:10px 0 8px;border-bottom:1px solid #f0efec;margin-bottom:14px;margin-top:4px}
.export-opt{display:block;padding:9px 16px;font-size:13px;color:#111;text-decoration:none;transition:background .1s}
.export-opt:hover{background:#f5f5f4}
.flex-1{flex:1}
.low-row td{background:#fef2f2!important}
.low-row:hover td{background:#fee2e2!important}
.ebay-status-btn{padding:6px 14px;border-radius:7px;border:1px solid #ddd;background:#fff;font-size:12.5px;font-weight:500;cursor:pointer;transition:all .15s}
.ebay-status-btn.active{background:#0f172a;color:#fff;border-color:#0f172a}
.ebay-badge{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;padding:2px 9px;border-radius:5px;font-family:monospace}
.ebay-not-listed{background:#f3f4f6;color:#6b7280}
.ebay-listed{background:#dbeafe;color:#1d4ed8}
.ebay-sold{background:#fce7f3;color:#be185d}
.mod-hist-row{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid #f0efec;font-size:12.5px}
.mod-hist-row:last-child{border-bottom:none}
.lineage-link{display:inline-flex;align-items:center;gap:5px;font-size:12px;color:#1d4ed8;cursor:pointer;padding:5px 10px;border-radius:6px;border:1px solid #bfdbfe;background:#eff6ff;margin-top:4px}
.lineage-link:hover{background:#dbeafe}
</style>
<script>
const IS_ADMIN = {{ 'true' if session.get('role')=='admin' else 'false' }};
let allItems=[], selectedIds=new Set(), scanOpen=false, scanMode='lookup';
let pendingCheckoutId=null, pendingQtyId=null, qtyAction='add', debTimer=null, currentDetailId=null;
let pendingSaveData=null;

const ptypes    = {{ product_types | tojson }};
const companies = {{ companies | tojson }};
const CATEGORY_FIELDS = {{ category_fields | tojson }};  // {cat_id: [{field_label,field_key,field_type,placeholder,required}]}
const HW_CATS   = ['pc','server','workstation','laptop','desktop','computer'];

function loadItemsDebounced(){clearTimeout(debTimer);debTimer=setTimeout(loadItems,300)}

async function loadItems(){
  const q=document.getElementById('searchInput').value;
  const cat=document.getElementById('catFilter').value;
  const status=document.getElementById('statusFilter').value;
  const sort=document.getElementById('sortFilter').value;
  const ptype=document.getElementById('ptypeFilter').value;
  const params=new URLSearchParams({q,cat,status,sort,ptype});
  const items=await fetch('/api/items?'+params).then(r=>r.json());
  allItems=items; renderTable(items); updateStats(items); refreshAlertBadge();
  if(currentDetailId){const u=allItems.find(i=>i.id===currentDetailId);if(u)showDetail(u);}
}

function updateStats(items){
  document.getElementById('st-total').textContent=items.length;
  document.getElementById('st-out').textContent=items.filter(i=>i.checked_out).length;
  document.getElementById('st-low').textContent=items.filter(i=>i.is_low).length;
  const val=items.reduce((a,i)=>a+(i.cost_price||0)*(i.qty===null?1:(i.qty||0)),0);
  document.getElementById('st-val').textContent='$'+val.toFixed(0);
  document.getElementById('itemCount').textContent=items.length+' item'+(items.length===1?'':'s');
}

function renderTable(items){
  const tb=document.getElementById('itemTableBody');
  if(!items.length){tb.innerHTML=`<tr class="empty-row"><td colspan="9">No items found.</td></tr>`;return}
  tb.innerHTML=items.map(item=>{
    const catPill=item.category?`<span class="tag" style="background:${item.color}18;color:${item.color}">${item.category}</span>`:'';
    const serialSku=item.serial?`<span class="mono" style="font-size:12px">${item.serial}</span>`:(item.sku?`<span class="mono" style="font-size:12px;color:#64748b">SKU: ${item.sku}</span>`:'<span style="color:#ccc">—</span>');
    const shelf=item.shelf?`<span class="shelf">${item.shelf}</span>`:'—';
    const cond=item.condition?`<span style="font-size:11px;color:#64748b">${item.condition}</span>`:'';
    let status='';
    if(item.qty!==null){
      const warn=item.is_low?` style="color:#b91c1c;font-weight:600"`:'';
      status=`<span${warn}>${item.available} / ${item.qty}</span>${item.is_low?'<span style="font-size:10px;margin-left:4px;color:#b91c1c">🔴</span>':''}`;
    } else {
      status=item.checked_out?`<span class="tag tag-out">📤 ${item.checkout_by||'?'}</span>`:`<span class="tag tag-in">✓ In</span>`;
    }
    const cost=item.cost_price!=null?`<span style="font-size:12px;color:#475569">$${parseFloat(item.cost_price).toFixed(2)}</span>`:'<span style="color:#ddd">—</span>';
    let saleProfit='<span style="color:#ddd">—</span>';
    if(item.sale_price){
      const p=item.profit; const profStr=p!=null?(p>=0?`<span style="color:#15803d;font-size:10px"> +$${p.toFixed(2)}</span>`:`<span style="color:#b91c1c;font-size:10px"> -$${Math.abs(p).toFixed(2)}</span>`):'';
      saleProfit=`<span style="font-size:12px">$${parseFloat(item.sale_price).toFixed(2)}</span>${profStr}`;
    }
    const cbCol=IS_ADMIN?`<td style="padding:10px 8px 10px 14px" onclick="event.stopPropagation()"><input type="checkbox" class="row-cb" data-id="${item.id}" onchange="onRowCheck(this)" ${selectedIds.has(item.id)?'checked':''}></td>`:'';
    return `<tr class="${item.is_low?'low-row':''}${selectedIds.has(item.id)?' selected':''}" onclick="showDetail(allItems.find(i=>i.id===${item.id}))">
      ${cbCol}
      <td><div style="font-weight:500;font-size:13px">${item.name}</div>${item.manufacturer?`<div style="font-size:11px;color:#aaa">${item.manufacturer}</div>`:''}</td>
      <td>${catPill}</td>
      <td>${serialSku}</td>
      <td>${shelf}</td>
      <td>${cond}</td>
      <td>${status}</td>
      <td>${cost}<br>${saleProfit}</td>
      <td><button class="btn btn-secondary btn-sm" onclick="event.stopPropagation();editItem(allItems.find(i=>i.id===${item.id}))">Edit</button></td>
    </tr>`;
  }).join('');
}

function showDetail(item){
  if(!item)return; currentDetailId=item.id;
  document.getElementById('dp-name').textContent=item.name;
  document.getElementById('dp-model').textContent=[item.manufacturer,item.model].filter(Boolean).join(' · ');
  let statusHtml='';
  if(item.qty!==null) statusHtml=`<span class="tag ${item.is_low?'tag-out':'tag-in'}">${item.is_low?'🔴 Low':'✓'} ${item.available} available of ${item.qty}</span>`;
  else statusHtml=item.checked_out?`<span class="tag tag-out">📤 Out — ${item.checkout_by||'?'}</span>`:`<span class="tag tag-in">✓ Available</span>`;
  document.getElementById('dp-status').innerHTML=statusHtml;
  const rows=[];
  if(item.category) rows.push(['Category',item.category]);
  if(item.product_type) rows.push(['Type',item.product_type]);
  if(item.condition) rows.push(['Condition',item.condition]);
  if(item.owner_company) rows.push(['Owner',item.owner_company]);
  if(item.purchase_date) rows.push(['Purchased',item.purchase_date]);
  if(item.serial) rows.push(['Serial',`<span class="mono">${item.serial}</span>`]);
  if(item.sku) rows.push(['SKU',`<span class="mono">${item.sku}</span>`]);
  if(item.shelf) rows.push(['Shelf',item.shelf]);
  if(item.cpu||item.ram||item.storage){
    if(item.cpu) rows.push(['CPU',item.cpu]);
    if(item.ram) rows.push(['RAM',item.ram]);
    if(item.storage) rows.push(['Storage',item.storage]);
  }
  if(item.cost_price!=null){
    let costStr=`$${parseFloat(item.cost_price).toFixed(2)}`;
    if(item.tax_paid===1) costStr+=` <span style="color:#94a3b8;font-size:11px">+ ${item.tax_rate||8.875}% tax = $${(item.cost_price*(1+(item.tax_rate||8.875)/100)).toFixed(2)} total</span>`;
    else if(item.tax_paid===0) costStr+=` <span style="color:#94a3b8;font-size:11px">(no tax)</span>`;
    rows.push(['Cost',costStr]);
  }
  if(item.sale_price!=null){
    const p=item.profit; rows.push(['Sale Price',`$${parseFloat(item.sale_price).toFixed(2)}${p!=null?(p>=0?` <span style="color:#15803d">+$${p.toFixed(2)} profit</span>`:`<span style="color:#b91c1c">-$${Math.abs(p).toFixed(2)} loss</span>`):''}` ]);
  }
  if(item.is_low) rows.push(['Low Stock','🔴 Below threshold ('+item.low_stock_threshold+')']);
  if(item.checked_out){rows.push(['Out Since',item.checkout_date||'—']);rows.push(['Job Ref',item.job_ref||'—']);}
  // eBay status row
  const ebayStatus=item.ebay_status||'not_listed';
  const ebayBadge=ebayStatus==='listed'?`<span class="ebay-badge ebay-listed">eBay: Listed${item.ebay_listing_id?' #'+item.ebay_listing_id:''}</span>`:ebayStatus==='sold'?`<span class="ebay-badge ebay-sold">eBay: Sold${item.ebay_listing_id?' #'+item.ebay_listing_id:''}</span>`:`<span class="ebay-badge ebay-not-listed">eBay: Not Listed</span>`;
  rows.push(['eBay',ebayBadge+` <button class="btn btn-secondary btn-sm" style="font-size:10px;padding:2px 8px;margin-left:4px" onclick="openEbay(${item.id})">Update</button>`]);
  // Parent item lineage
  if(item.parent_item_id) rows.push(['Origin','<span class="lineage-link" onclick="jumpToItem('+item.parent_item_id+')">⬆ View parent item (ID '+item.parent_item_id+')</span>']);
  if(item.notes) rows.push(['Notes',item.notes]);
  document.getElementById('dp-fields').innerHTML=rows.map(([l,v])=>`<div class="dl-row"><div class="dl-l">${l}</div><div class="dl-v">${v}</div></div>`).join('');
  let acts='';
  if(item.sold){
    acts=`<div style="background:#f5f3ff;border-radius:7px;padding:10px 12px;font-size:12.5px;color:#7c3aed;font-weight:500">✓ Sold — $${parseFloat(item.sold_price||0).toFixed(2)}${item.sold_to?' to '+item.sold_to:''}<br><span style="font-weight:400;color:#94a3b8">${item.sold_date||''}</span></div>`;
  } else if(item.qty!==null){
    acts=`<button class="btn btn-primary" onclick="openQtyAdjust(${item.id})">Adjust Quantity</button>`;
  } else if(item.checked_out){
    acts=`<button class="btn btn-success" onclick="doCheckin(${item.id})">📥 Check In</button>`;
  } else {
    acts=`<button class="btn btn-danger" onclick="openCheckout(${item.id})">📤 Check Out</button>`;
    if(item.sale_price||item.product_type==='For Sale'){
      acts+=`<button class="btn btn-secondary" style="background:#f5f3ff;color:#7c3aed;border-color:#ddd6fe" onclick="openSell(${item.id})">💰 Sell</button>`;
    }
  }
  acts+=`<button class="btn btn-secondary" onclick="editItem(allItems.find(i=>i.id===${item.id}))">Edit</button>`;
  acts+=`<button class="btn btn-secondary" onclick="openModify(${item.id})" title="Log a component change (RAM, CPU, etc.)">🔧 Modify</button>`;
  acts+=`<button class="btn btn-secondary" onclick="printLabel(${item.id})" style="font-size:11px">🏷 Print Label</button>`;
  document.getElementById('dp-actions').innerHTML=acts;
  // Load modification history async
  loadModHistory(item.id);
  // Load child items async
  loadChildItems(item.id);
  document.getElementById('detailPanel').classList.remove('hidden');
}
function closeDetail(){document.getElementById('detailPanel').classList.add('hidden');currentDetailId=null;}

// ── Sell ──
let pendingSellId=null;
function openSell(id){
  const item=allItems.find(i=>i.id===id);if(!item)return;
  pendingSellId=id;
  document.getElementById('sell-name').textContent=item.name;
  document.getElementById('sell-cost').textContent=item.cost_price!=null?parseFloat(item.cost_price).toFixed(2):'—';
  document.getElementById('sell-listed').textContent=item.sale_price!=null?parseFloat(item.sale_price).toFixed(2):'—';
  document.getElementById('sell-price').value=item.sale_price||'';
  document.getElementById('sell-to').value='';
  updateSellProfit();
  openModal('sellModal');
}
function updateSellProfit(){
  const item=allItems.find(i=>i.id===pendingSellId);
  const price=parseFloat(document.getElementById('sell-price').value)||0;
  const cost=item?.cost_price||0;
  const el=document.getElementById('sell-profit-preview');
  if(price>0&&cost>0){
    const p=price-cost;const pct=((p/cost)*100).toFixed(1);
    el.innerHTML=p>=0?`<span style="color:#15803d">Profit: $${p.toFixed(2)} (+${pct}%)</span>`:`<span style="color:#b91c1c">Loss: $${Math.abs(p).toFixed(2)} (${pct}%)</span>`;
  } else el.innerHTML='<span style="color:#94a3b8">Enter sale price to see profit</span>';
}
async function confirmSell(){
  const price=document.getElementById('sell-price').value;
  if(!price){toast('Enter sale price','warn');return}
  const res=await api('/api/item/sell',{id:pendingSellId,price:parseFloat(price),sold_to:document.getElementById('sell-to').value.trim()});
  if(res.ok){
    toast(`Sold ✓  Profit: $${res.profit>=0?'+':''}${parseFloat(res.profit).toFixed(2)}`,'ok');
    closeModal('sellModal');await loadItems();
    const u=allItems.find(i=>i.id===pendingSellId);if(u)showDetail(u);
  } else toast(res.msg||'Error','err');
}

// ── Label Printing ──
let labelItems=[];
function printLabel(id){
  const item=allItems.find(i=>i.id===id);if(!item)return;
  labelItems=[item];
  renderLabels();
  openModal('labelModal');
}
function printSelectedLabels(){
  labelItems=allItems.filter(i=>selectedIds.has(i.id));
  if(!labelItems.length){toast('Select items first','warn');return}
  renderLabels();
  openModal('labelModal');
}
function renderLabels(){
  const fmt=document.querySelector('input[name="label-fmt"]:checked')?.value||'single';
  const preview=document.getElementById('labelPreview');
  if(!labelItems.length){preview.innerHTML='<div style="color:#94a3b8;text-align:center;padding:30px">No items selected</div>';return}

  const makeLabel=(item,size)=>{
    const code=item.serial||item.sku||('ID-'+String(item.id));
    const isSingle=(size==='single');
    // Barcode SVG — rendered after insertion via JsBarcode
    const bcId='bc-'+item.id+'-'+Math.random().toString(36).slice(2,6);
    const qrId='qr-'+item.id+'-'+Math.random().toString(36).slice(2,6);
    const bcH=isSingle?36:22;
    return `<div class="label-box ${isSingle?'label-single-box':''}">
      <div class="label-top">
        <div class="label-info">
          <div class="label-name">${item.name}</div>
          ${item.manufacturer?`<div class="label-mfr">${item.manufacturer}${item.model?' · '+item.model:''}</div>`:''}
          <div class="label-meta">
            ${item.serial?`<span>SN: <strong>${item.serial}</strong></span>`:''}
            ${item.sku&&!item.serial?`<span>SKU: <strong>${item.sku}</strong></span>`:''}
            ${item.shelf?`<span>📍 ${item.shelf}</span>`:''}
          </div>
          <div class="label-brand">Storelax · DSS Management</div>
        </div>
        <canvas id="${qrId}" class="label-qr-canvas"></canvas>
      </div>
      <div class="label-barcode-wrap">
        <svg id="${bcId}" class="label-barcode"></svg>
      </div>
    </div>
    <script>
      (function(){
        var attempts=0;
        function tryRender(){
          try{
            JsBarcode('#${bcId}','${code.replace(/'/g,"\\'")}',{format:'CODE128',width:${isSingle?2:1.3},height:${bcH},displayValue:true,fontSize:${isSingle?11:7},margin:0,background:'#ffffff',lineColor:'#0f172a',font:'IBM Plex Mono, monospace'});
            var qc=document.getElementById('${qrId}');
            if(typeof QRCode!=='undefined'&&qc){QRCode.toCanvas(qc,'${code.replace(/'/g,"\\'")}',{width:${isSingle?64:44},margin:1,color:{dark:'#0f172a',light:'#ffffff'}},function(){});}
          }catch(e){if(attempts++<10)setTimeout(tryRender,100);}
        }
        tryRender();
      })();
    <\/script>`;
  };

  const styles=`<style>
    .label-sheet{display:flex;flex-wrap:wrap;gap:0;padding:8px}
    .label-box{width:2.625in;height:1in;border:1px dashed #ccc;padding:4px 5px 3px;
      box-sizing:border-box;display:flex;flex-direction:column;background:#fff;overflow:hidden}
    .label-top{display:flex;align-items:flex-start;gap:4px;flex:1;min-height:0}
    .label-info{flex:1;min-width:0}
    .label-name{font-size:8.5px;font-weight:700;text-transform:uppercase;letter-spacing:.3px;
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:sans-serif;line-height:1.2}
    .label-mfr{font-size:6.5px;color:#555;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3}
    .label-meta{display:flex;gap:5px;flex-wrap:wrap;margin-top:1px}
    .label-meta span{font-size:6.5px;color:#333;font-family:monospace;line-height:1.4}
    .label-brand{font-size:5.5px;color:#bbb;margin-top:2px;letter-spacing:.3px}
    .label-qr-canvas{flex-shrink:0;width:44px!important;height:44px!important;image-rendering:pixelated}
    .label-barcode{width:100%;height:22px;display:block;margin-top:2px}
    .label-barcode-wrap{width:100%;flex-shrink:0}
    /* Single label */
    .label-wrap-single{display:flex;justify-content:center;padding:20px}
    .label-single-box{width:3.5in!important;height:1.5in!important;padding:8px 10px 6px!important;border:2px solid #0f172a!important;border-radius:6px!important}
    .label-single-box .label-name{font-size:13px!important}
    .label-single-box .label-mfr{font-size:9px!important}
    .label-single-box .label-meta span{font-size:9px!important}
    .label-single-box .label-brand{font-size:8px!important}
    .label-single-box .label-qr-canvas{width:64px!important;height:64px!important}
    .label-single-box .label-barcode{height:36px!important}
    @media print{
      .label-sheet{padding:0.5in 0.18in}
      .label-box{page-break-inside:avoid;border-color:#ccc}
      @page{margin:0}
    }
  </style>`;

  if(fmt==='sheet'){
    const labels=labelItems.map(i=>makeLabel(i,'sheet'));
    while(labels.length<30&&labels.length<labelItems.length*6)
      labels.push(...labelItems.slice(0,Math.min(labelItems.length,30-labels.length)).map(i=>makeLabel(i,'sheet')));
    preview.innerHTML=`${styles}<div id="printArea"><div class="label-sheet">${labels.slice(0,30).join('')}</div></div>`;
  } else {
    preview.innerHTML=`${styles}<div id="printArea"><div class="label-wrap-single">${makeLabel(labelItems[0],'single')}</div></div>`;
  }
}

// QR helper — used only as fallback if inline script fails
function generateQR(text){
  try{
    const c=document.createElement('canvas');
    QRCode.toCanvas(c,text,{width:64,margin:1,color:{dark:'#0f172a',light:'#ffffff'}},()=>{});
    return `<img src="${c.toDataURL()}" width="52" height="52" style="display:block">`;
  }catch(e){return '';}
}

